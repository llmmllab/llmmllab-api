# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=lsm
DB_PASSWORD=
DB_NAME=llmmllab
DB_SSLMODE=disable

# Redis (optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CONVERSATION_TTL=360
REDIS_MESSAGE_TTL=180
REDIS_SUMMARY_TTL=720
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNECTIONS=2
REDIS_CONNECT_TIMEOUT=5

# Auth
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_JWKS_URI=
# Set TEST_USER_ID to seed a local dev user + API key on startup:
# TEST_USER_ID=local-dev-user
# The plaintext API key is saved to .env.local (gitignored)

# HuggingFace
HF_TOKEN=

# Images
IMAGE_DIR=/tmp/images
IMAGE_RETENTION_HOURS=24

# Internal API
INTERNAL_API_KEY=
INTERNAL_ALLOWED_IPS=127.0.0.1

# Logging
LOG_LEVEL=info
FORCE_COLOR=1

# CUDA / GPU
CUDA_VISIBLE_DEVICES=0
CUDA_DEVICE_ORDER=PCI_BUS_ID
PYTHONMALLOC=malloc
MALLOC_ARENA_MAX=2
GGML_LOG_LEVEL=2

# Search
SEARX_HOST=

# Server
PORT=9999
