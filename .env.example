# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=lsm
DB_PASSWORD=
DB_NAME=llmmllab
DB_SSLMODE=disable
DB_MAINTENANCE_INTERVAL_HOURS=24
DB_MAINTENANCE_INITIAL_DELAY_SECONDS=300
DB_REINDEX_ON_MAINTENANCE=false

# Redis (optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CONVERSATION_TTL=360
REDIS_MESSAGE_TTL=180
REDIS_SUMMARY_TTL=720
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNECTIONS=2
REDIS_CONNECT_TIMEOUT=5

# Auth
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_JWKS_URI=
# Set TEST_USER_ID to seed a local dev user + API key on startup:
# TEST_USER_ID=local-dev-user
# The plaintext API key is saved to .env.local (gitignored)

# External API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HF_TOKEN=
SEARX_HOST=

# Images
IMAGE_DIR=/tmp/images
IMAGE_RETENTION_HOURS=24
CONFIG_DIR=/app/config
HF_HOME=/root/.cache/huggingface

# Logging
LOG_LEVEL=info
LOG_FORMAT=console
FORCE_COLOR=1

# Runner / Inference
RUNNER_ENDPOINTS=http://localhost:9000
RUNNER_RETRIES=2
RUNNER_RETRY_BACKOFF_BASE=1
RUNNER_HEALTH_TIMEOUT_SEC=5.0
RUNNER_FAST_TIMEOUT_SEC=10.0
RUNNER_ACQUIRE_TIMEOUT_SEC=150.0
RUNNER_MAX_ACQUIRE_FAILURES=3
RUNNER_UNHEALTHY_WINDOW_SEC=60.0
RUNNER_ACQUIRE_RETRIES=2
MODEL_CACHE_REFRESH_SEC=60
STALE_SERVER_RETRIES=1

# Priority Queue
PRIORITY_QUEUE_ENABLED=true
PRIORITY_QUEUE_MAX_SIZE=100
PRIORITY_QUEUE_TIMEOUT_SEC=300
PRIORITY_QUEUE_AGE_THRESHOLD_SEC=60
PRIORITY_QUEUE_MAX_WAIT_MIN_SEC=1
PRIORITY_QUEUE_MAX_WAIT_MAX_SEC=3600

# Chat / LLM
CHAT_OPENAI_MAX_RETRIES=2
ENABLE_TOOL_CONTINUATION=true

# Tracing
TEMPO_ENDPOINT=http://tempo.llmmllab.svc.cluster.local:4317

# CUDA / GPU
CUDA_VISIBLE_DEVICES=0
CUDA_DEVICE_ORDER=PCI_BUS_ID
PYTHONMALLOC=malloc
MALLOC_ARENA_MAX=2
GGML_LOG_LEVEL=2
