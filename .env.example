# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=lsm
DB_PASSWORD=
DB_NAME=llmmllab
DB_SSLMODE=disable

# Redis (optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CONVERSATION_TTL=360
REDIS_MESSAGE_TTL=180
REDIS_SUMMARY_TTL=720
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNECTIONS=2
REDIS_CONNECT_TIMEOUT=5

# Auth
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_JWKS_URI=
# Set TEST_USER_ID to seed a local dev user + API key on startup:
# TEST_USER_ID=local-dev-user
# The plaintext API key is saved to .env.local (gitignored)

# HuggingFace
HF_TOKEN=

# Images
IMAGE_DIR=/tmp/images
IMAGE_RETENTION_HOURS=24

# Vision token accounting (services/token_counter.py).
# Image blocks in multimodal messages cost real vision tokens at the
# runner side (mmproj produces ~700-2500 tokens per image), but
# llama.cpp's text /tokenize endpoint can't see them.  These knobs
# let the api's pre-trim guard estimate those tokens so it matches
# what the runner actually receives.  Defaults are calibrated for
# Qwen2/3-VL family.
IMAGE_TOKENS_DEFAULT=1500
VISION_PATCH_PX=28
VISION_MAX_LONG_EDGE_PX=1280

# Image-server lifecycle.  When true, sd-server / qwen-image servers
# are torn down after each request instead of held warm.  Default true
# because image servers are 4-12 GB resident and re-use is rare in
# interactive workflows.  Set false for benchmarking or batched gen.
IMG_SERVER_AUTO_SHUTDOWN=true

# Tracing — OTLP gRPC endpoint for OpenTelemetry trace export.
# Defaults to the in-cluster Tempo service; set to empty to disable.
TEMPO_ENDPOINT=http://tempo.llmmllab.svc.cluster.local:4317

# Database maintenance (db/maintenance.py).
DB_MAINTENANCE_INTERVAL_HOURS=24
DB_MAINTENANCE_INITIAL_DELAY_SECONDS=300
# REINDEX during maintenance.  Off by default — REINDEX CONCURRENTLY
# can still trip stale-OID plan errors under live TimescaleDB traffic.
DB_REINDEX_ON_MAINTENANCE=false

# Internal API
INTERNAL_API_KEY=
INTERNAL_ALLOWED_IPS=127.0.0.1

# Logging
LOG_LEVEL=info
FORCE_COLOR=1

# CUDA / GPU
CUDA_VISIBLE_DEVICES=0
CUDA_DEVICE_ORDER=PCI_BUS_ID
PYTHONMALLOC=malloc
MALLOC_ARENA_MAX=2
GGML_LOG_LEVEL=2

# Search
SEARX_HOST=

# Server
PORT=9999
